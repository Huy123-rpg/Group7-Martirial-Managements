<Window x:Class="WPF.PresentationLayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WPF.PresentationLayer.ViewModels"
        Title="Quản lý Kho"
        Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBackground}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════ SIDEBAR ══════════════════ -->
        <Grid Grid.Column="0" Background="#1A1A1A">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- App Title -->
            <StackPanel Grid.Row="0" Margin="24,28,24,20">
                <TextBlock Text="QUẢN LÝ KHO"
                           Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>
                <TextBlock Text="Warehouse Management"
                           Foreground="#666666" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Divider -->
            <Rectangle Grid.Row="1" Height="1" Fill="#2D2D2D" Margin="0,0,0,8"/>

            <!-- Menu Items -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- ── Tổng quan (luôn hiển thị) ─── -->
                    <TextBlock Text="TỔNG QUAN"
                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                               Margin="24,12,0,6"/>
                    <Button Content="  📊  Tổng quan"
                            Style="{StaticResource SidebarMenuItem}"
                            Command="{Binding NavDashboardCommand}"/>

                    <!-- ── Quản trị (Admin) ─── -->
                    <TextBlock x:Name="MenuHeaderAdmin"
                               Text="QUẢN TRỊ"
                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                               Margin="24,12,0,6" Visibility="Collapsed"/>
                    <Button x:Name="BtnUsers"
                            Content="  👥  Người dùng"
                            Style="{StaticResource SidebarMenuItem}"
                            Command="{Binding NavUserManagementCommand}"
                            Visibility="Collapsed"/>

                    <!-- ── Quản lý kho (Admin + Manager) ─── -->
                    <TextBlock x:Name="MenuHeaderWarehouse"
                               Text="QUẢN LÝ KHO"
                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                               Margin="24,12,0,6" Visibility="Collapsed"/>
                    <Button x:Name="BtnWarehouseConfig"
                            Content="  🏭  Cấu hình kho &amp; zone"
                            Style="{StaticResource SidebarMenuItem}"
                            Command="{Binding NavWarehouseConfigCommand}"
                            Visibility="Collapsed"/>

                    <!-- 📦 Tra cứu tồn kho (Tất cả trừ Supplier) -->
                    <TextBlock x:Name="MenuHeaderInventory"
                               Text="KHO &amp; TỒN KHO"
                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                               Margin="24,12,0,6"/>
                    <Button x:Name="BtnInventoryLookup"
                            Content="  📦  Tra cứu tồn kho"
                            Style="{StaticResource SidebarMenuItem}"
                            Command="{Binding NavInventoryLookupCommand}" />

                    <Button x:Name="BtnStockCountExecution"
                            Content="  📋  Thực hiện kiểm kho"
                            Style="{StaticResource SidebarMenuItem}"
                            Command="{Binding NavStockCountExecutionCommand}" />

                    <Button x:Name="BtnStockCountApproval"
                            Content="  📝  Duyệt kiểm kê kho"
                            Style="{StaticResource SidebarMenuItem}"
                            Command="{Binding NavStockCountApprovalCommand}"
                            Visibility="Collapsed"/>

                    <!-- ── Phân công (Admin + Manager) ─── -->
                    <TextBlock x:Name="MenuHeaderSchedule"
                               Text="PHÂN CÔNG"
                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                               Margin="24,12,0,6" Visibility="Collapsed"/>
                    <Button x:Name="BtnSchedule"
                            Content="  🗓  Phân công nhiệm vụ"
                            Style="{StaticResource SidebarMenuItem}"
                            Command="{Binding NavScheduleCommand}"
                            Visibility="Collapsed"/>

                    <!-- ── Lịch của tôi (Staff) ─── -->
                    <TextBlock x:Name="MenuHeaderMySchedule"
                               Text="CÔNG VIỆC"
                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                               Margin="24,12,0,6" Visibility="Collapsed"/>
                    <Button x:Name="BtnMySchedule"
                            Content="  📅  Lịch của tôi"
                            Style="{StaticResource SidebarMenuItem}"
                            Command="{Binding NavMyScheduleCommand}"
                            Visibility="Collapsed"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Bottom: User info + Logout -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Rectangle Grid.Row="0" Height="1" Fill="#2D2D2D"/>

                <StackPanel Grid.Row="1" Margin="24,14,24,10">
                    <TextBlock Text="{Binding CurrentUserName}"
                               Foreground="#EEEEEE" FontSize="12" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding CurrentUserRole}"
                               Foreground="#777777" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Row="2"
                        Content="Đăng xuất"
                        Style="{StaticResource SidebarLogout}"
                        Margin="0,0,0,16"
                        Command="{Binding LogoutCommand}"/>
            </Grid>
        </Grid>

        <!-- ══════════════════ MAIN AREA ══════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="54"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0"
                               Text="{Binding CurrentPageTitle}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <!-- Notification Bell -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ToggleButton x:Name="NotificationToggle"
                                      Width="32" Height="32"
                                      Background="Transparent" BorderThickness="0"
                                      Cursor="Hand">
                            <Grid>
                                <TextBlock Text="🔔" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border Background="#D32F2F" Width="8" Height="8" CornerRadius="4"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,4,4,0"
                                        Visibility="{Binding HasUnreadNotifications, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=NotificationToggle}"
                               StaysOpen="False" PlacementTarget="{Binding ElementName=NotificationToggle}"
                               Placement="Bottom" HorizontalOffset="-260" VerticalOffset="10">
                            <Border Width="300" Background="{StaticResource BrushSurface}"
                                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                    CornerRadius="6" Padding="0,0,0,8" Margin="0,0,8,8">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="10" ShadowDepth="4"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Panel Header -->
                                    <Border Grid.Row="0" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1" Padding="16,12">
                                        <TextBlock Text="Thông báo mới" FontWeight="SemiBold" FontSize="14"/>
                                    </Border>

                                    <!-- Notification List -->
                                    <ScrollViewer Grid.Row="1" MaxHeight="350" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding UnreadNotifications}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1" Padding="16,12" Background="Transparent">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Body}" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                                <TextBlock Text="{Binding CreatedAt, StringFormat='dd/MM/yyyy HH:mm'}" Foreground="#999" FontSize="11"/>
                                                            </StackPanel>
                                                            <!-- Buttons -->
                                                            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                                                                <!-- View Detail -->
                                                                <Button Command="{Binding DataContext.ViewNotificationDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" Margin="0,0,0,8">
                                                                    <TextBlock Text="👁" Foreground="#666" FontSize="14" ToolTip="Xem chi tiết"/>
                                                                </Button>
                                                                <!-- Mark Read -->
                                                                <Button Command="{Binding DataContext.MarkNotificationReadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4">
                                                                    <TextBlock Text="🗑" Foreground="#999" FontSize="14" ToolTip="Đánh dấu đã đọc"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            
                                            <!-- Empty state -->
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasUnreadNotifications}" Value="False">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate>
                                                                        <TextBlock Text="Không có thông báo mới."
                                                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                                                   FontStyle="Italic" TextAlignment="Center" Margin="0,30"/>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>
