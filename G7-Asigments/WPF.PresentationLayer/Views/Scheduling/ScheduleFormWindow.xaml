<Window x:Class="WPF.PresentationLayer.Views.Scheduling.ScheduleFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBox" x:Key="Input">
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="Margin"  Value="0,0,0,12"/>
        </Style>
        <Style TargetType="ComboBox" x:Key="Combo">
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="Margin"  Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>  <!-- Loại + Kho -->
            <RowDefinition Height="Auto"/>  <!-- Bắt đầu -->
            <RowDefinition Height="Auto"/>  <!-- Phân công -->
            <RowDefinition Height="Auto"/>  <!-- Tài liệu liên quan -->
            <RowDefinition Height="Auto"/>  <!-- Lặp lại -->
            <RowDefinition Height="Auto"/>  <!-- Ghi chú -->
            <RowDefinition Height="Auto"/>  <!-- Conflict warning -->
            <RowDefinition Height="Auto"/>  <!-- Error -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <StackPanel Grid.Row="0" Margin="0,0,0,0">
            <TextBlock Text="Tiêu đề *" Style="{StaticResource Label}"/>
            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Input}"/>
        </StackPanel>

        <!-- Loại lịch + Kho -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Loại lịch *" Style="{StaticResource Label}"/>
                <ComboBox ItemsSource="{Binding ScheduleTypes}"
                          SelectedItem="{Binding ScheduleType}"
                          DisplayMemberPath="TypeName"
                          Style="{StaticResource Combo}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Kho *" Style="{StaticResource Label}"/>
                <ComboBox ItemsSource="{Binding Warehouses}"
                          SelectedItem="{Binding Warehouse}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource Combo}"/>
            </StackPanel>
        </Grid>

        <!-- Bắt đầu (ngày + giờ) -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Bắt đầu *" Style="{StaticResource Label}"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <DatePicker Grid.Column="0" SelectedDate="{Binding StartDate}"/>
                <TextBox Grid.Column="2"
                         Text="{Binding StartHour, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Input}"
                         Tag="HH:mm"/>
            </Grid>
        </StackPanel>

        <!-- Phân công cho -->
        <StackPanel Grid.Row="3">
            <TextBlock Text="Phân công cho" Style="{StaticResource Label}"/>
            <ComboBox ItemsSource="{Binding StaffUsers}"
                      SelectedItem="{Binding AssignedTo}"
                      DisplayMemberPath="FullName"
                      Style="{StaticResource Combo}"/>
        </StackPanel>

        <!-- Tài liệu liên quan -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Tài liệu liên quan (tuỳ chọn)" Style="{StaticResource Label}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding RefTypes}"
                          SelectedItem="{Binding SelectedRefType}"
                          Style="{StaticResource Combo}"/>
                <TextBox Grid.Column="2"
                         Text="{Binding RefId, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding HasRefType}"
                         Style="{StaticResource Input}"
                         Tag="Nhập ID tài liệu..."/>
            </Grid>
        </StackPanel>

        <!-- Lặp lại (recurring) -->
        <StackPanel Grid.Row="5" Margin="0,0,0,12">
            <CheckBox Content="Lặp lại lịch này" IsChecked="{Binding IsRecurring}"
                      Margin="0,0,0,8" FontWeight="SemiBold"/>
            <Grid Visibility="{Binding ShowRecurrence, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Tần suất" Style="{StaticResource Label}"/>
                    <ComboBox ItemsSource="{Binding RecurrenceOptions}"
                              SelectedItem="{Binding SelectedRecurrence}"
                              DisplayMemberPath="Label"
                              Style="{StaticResource Combo}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Số lần" Style="{StaticResource Label}"/>
                    <TextBox Text="{Binding RecurrenceCount, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Input}"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Ghi chú -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="Ghi chú" Style="{StaticResource Label}"/>
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" Height="72" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Style="{StaticResource Input}"/>
        </StackPanel>

        <!-- Conflict Warning -->
        <Border Grid.Row="7" Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1"
                CornerRadius="4" Padding="10,8" Margin="0,0,0,12"
                Visibility="{Binding HasConflicts, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="⚠ Cảnh báo: Phát hiện lịch trùng thời gian"
                           FontWeight="Bold" Foreground="#856404" Margin="0,0,0,4"/>
                <ItemsControl ItemsSource="{Binding Conflicts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Foreground="#856404" FontSize="12"
                                       Text="{Binding Title, StringFormat='• {0}'}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Error -->
        <TextBlock Grid.Row="8" Text="{Binding ErrorMessage}"
                   Foreground="Red" TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Hủy" Command="{Binding CancelCommand}"
                    Padding="20,8" Margin="0,0,8,0"
                    Background="#E0E0E0"/>
            <Button Content="Lưu lịch" Command="{Binding SaveCommand}"
                    Padding="20,8"
                    Background="#1976D2" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
