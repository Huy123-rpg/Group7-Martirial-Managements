<UserControl x:Class="WPF.PresentationLayer.Views.Scheduling.MyScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WPF.PresentationLayer.ViewModels.Scheduling">
    <UserControl.DataContext>
        <vm:MyScheduleViewModel/>
    </UserControl.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding TodayLabel}"
                   FontSize="18" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="▶ Bắt đầu thực hiện"
                    Command="{Binding StartCommand}"
                    Padding="14,8" Margin="0,0,8,0"
                    Background="#1976D2" Foreground="White"/>
            <Button Content="✓ Báo hoàn thành"
                    Command="{Binding CompleteCommand}"
                    Padding="14,8" Margin="0,0,8,0"
                    Background="#388E3C" Foreground="White"/>
            <Button Content="{Binding ToggleLabel}"
                    Command="{Binding ToggleHistoryCommand}"
                    Padding="14,8" Margin="0,0,8,0"
                    Background="#546E7A" Foreground="White"/>
            <Button Content="🔄 Làm mới"
                    Command="{Binding LoadCommand}"
                    Padding="14,8"
                    Background="#E0E0E0"/>
        </StackPanel>

        <!-- Schedule List -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Schedules}"
                  SelectedItem="{Binding Selected}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" SelectionMode="Single"
                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tiêu đề"    Binding="{Binding Title}"      Width="220"/>
                <DataGridTextColumn Header="Kho"        Binding="{Binding Warehouse.Name}" Width="130"/>
                <DataGridTextColumn Header="Loại"       Binding="{Binding ScheduleTypeNavigation.TypeName}" Width="110"/>
                <DataGridTextColumn Header="Bắt đầu"    Binding="{Binding StartTime, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                <DataGridTemplateColumn Header="Trạng thái" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,2"
                                    Background="{Binding StatusCode, Converter={StaticResource StatusToBrush}}">
                                <TextBlock Text="{Binding StatusCode, Converter={StaticResource StatusToLabel}}"
                                           Foreground="White" FontSize="11" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Ghi chú"    Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Detail Panel -->
        <Border Grid.Row="3" Margin="0,8,0,0" Padding="16,12"
                Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                CornerRadius="4"
                Visibility="{Binding Selected, Converter={StaticResource NullToVisibility}}">
            <StackPanel>
                <!-- Header: badge + title -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Border Background="{Binding Selected.StatusCode, Converter={StaticResource StatusToBrush}}"
                            CornerRadius="4" Padding="8,3" Margin="0,0,10,0">
                        <TextBlock Text="{Binding Selected.StatusCode, Converter={StaticResource StatusToLabel}}"
                                   Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                    </Border>
                    <TextBlock Text="{Binding Selected.Title}"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Row 1: Kho | Loại | Bắt đầu -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Kho" Foreground="#888" FontSize="11" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding Selected.Warehouse.Name, TargetNullValue='—'}"
                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Loại lịch" Foreground="#888" FontSize="11" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding Selected.ScheduleTypeNavigation.TypeName, TargetNullValue='—'}"
                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Bắt đầu" Foreground="#888" FontSize="11" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding Selected.StartTime, StringFormat=dd/MM/yyyy\ HH:mm}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
                <!-- Hướng dẫn hành động dựa trên trạng thái -->
                <Border Margin="0,10,0,0" Padding="10,6" CornerRadius="3"
                        Background="{Binding StatusColor}"
                        Visibility="{Binding StatusLabel, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="{Binding StatusLabel}" Foreground="White" FontWeight="SemiBold"/>
                </Border>
                <!-- Ghi chú -->
                <StackPanel Margin="0,8,0,0"
                            Visibility="{Binding Selected.Description, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="Ghi chú" Foreground="#888" FontSize="11" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding Selected.Description}"
                               TextWrapping="Wrap" Foreground="#444" MaxHeight="48"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
