<UserControl x:Class="WPF.PresentationLayer.Views.Scheduling.ScheduleListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WPF.PresentationLayer.ViewModels.Scheduling">
    <UserControl.DataContext>
        <vm:ScheduleViewModel/>
    </UserControl.DataContext>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBox Grid.Row="0" Width="220" Margin="0,0,0,8" HorizontalAlignment="Right"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Schedules}"
                  SelectedItem="{Binding Selected}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tiêu đề"     Binding="{Binding Title}"      Width="200"/>
                <DataGridTextColumn Header="Kho"         Binding="{Binding Warehouse.Name}" Width="150"/>
                <DataGridTextColumn Header="Loại lịch"   Binding="{Binding ScheduleType.TypeName}" Width="130"/>
                <DataGridTextColumn Header="Ngày"        Binding="{Binding ScheduledDate, StringFormat=dd/MM/yyyy}" Width="110"/>
                <DataGridTextColumn Header="Phân công"   Binding="{Binding AssignedTo.FullName}" Width="150"/>
                <DataGridTextColumn Header="Trạng thái"  Binding="{Binding StatusId}"   Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
