<UserControl x:Class="WPF.PresentationLayer.Views.Import.PurchaseOrderListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WPF.PresentationLayer.ViewModels.Import">
    <UserControl.DataContext>
        <vm:PurchaseOrderViewModel/>
    </UserControl.DataContext>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search + Actions -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" HorizontalAlignment="Right">
            <TextBox Width="220" Margin="0,0,8,0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"
                     x:Name="txtSearch"/>
            <!-- TODO: Add/Edit buttons -->
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Orders}"
                  SelectedItem="{Binding Selected}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Số PO"       Binding="{Binding PoNumber}"   Width="130"/>
                <DataGridTextColumn Header="Nhà cung cấp" Binding="{Binding Supplier.SupplierName}" Width="200"/>
                <DataGridTextColumn Header="Kho"         Binding="{Binding Warehouse.Name}" Width="150"/>
                <DataGridTextColumn Header="Ngày đặt"   Binding="{Binding OrderDate, StringFormat=dd/MM/yyyy}" Width="110"/>
                <DataGridTextColumn Header="Ngày nhận dự kiến" Binding="{Binding ExpectedDate, StringFormat=dd/MM/yyyy}" Width="140"/>
                <DataGridTextColumn Header="Tổng tiền"  Binding="{Binding TotalAmount, StringFormat=N0}" Width="120"/>
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding StatusId}"   Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
