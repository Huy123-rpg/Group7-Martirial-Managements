<Window x:Class="WPF.PresentationLayer.Views.Import.GoodsReceiptAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phiếu nhập kho"
        Height="680" Width="960"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Phiếu nhập kho"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <!-- PO Reference Banner (visible only when created from PO) -->
        <Border x:Name="pnlPoRef" Grid.Row="1"
                Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Tham chiếu PO: " FontWeight="SemiBold" Foreground="#1D4ED8"/>
                <TextBlock x:Name="txtPoRef" Foreground="#1D4ED8"/>
                <TextBlock Text="  |  Nhà cung cấp: " Foreground="#6B7280"/>
                <TextBlock x:Name="txtPoSupplier" Foreground="#374151"/>
                <TextBlock Text="  |  Kho: " Foreground="#6B7280"/>
                <TextBlock x:Name="txtPoWarehouse" Foreground="#374151"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Mã phiếu"/>
                <TextBox x:Name="txtCode" Height="34" IsReadOnly="True" Background="#F3F4F6"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Ngày nhập"/>
                <DatePicker x:Name="dpDate" Height="34"/>
            </StackPanel>

            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="Nhà cung cấp"/>
                <ComboBox x:Name="cbSupplier"
                          DisplayMemberPath="SupplierName"
                          SelectedValuePath="Id"
                          Height="34"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="Kho nhập"/>
                <ComboBox x:Name="cbWarehouse"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          Height="34"/>
            </StackPanel>

            <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2">
                <TextBlock Text="Ghi chú"/>
                <TextBox x:Name="txtNote" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <GroupBox Grid.Row="3" Header="Chi tiết phiếu nhập" FontWeight="SemiBold">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel x:Name="pnlItemButtons" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Thêm dòng"
                            Width="100"
                            Height="32"
                            Click="BtnAddItem_Click"/>
                    <Button Content="Xóa dòng"
                            Width="100"
                            Height="32"
                            Margin="10,0,0,0"
                            Click="BtnDeleteItem_Click"/>
                </StackPanel>

                <DataGrid x:Name="dgItems"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Sản phẩm" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="ProductName"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding ProductId, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"
                                              StaysOpenOnEdit="True"
                                              LostFocus="ProductComboBox_LostFocus"
                                              SelectionChanged="ProductComboBox_SelectionChanged" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="SL đặt (PO)"
                                            Width="100"
                                            Binding="{Binding QtyOrdered, StringFormat=N0}"
                                            IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#6B7280"/>
                                    <Setter Property="FontStyle" Value="Italic"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="SL nhập"
                                            Width="100"
                                            Binding="{Binding QtyReceived, ValidatesOnExceptions=True, TargetNullValue=0, FallbackValue=0}"/>

                        <DataGridTextColumn Header="Đơn giá"
                                            Width="110"
                                            Binding="{Binding UnitCost, ValidatesOnExceptions=True, TargetNullValue=0, FallbackValue=0}"/>

                        <DataGridTextColumn Header="Thành tiền"
                                            Width="120"
                                            IsReadOnly="True"
                                            Binding="{Binding LineTotal, StringFormat=N0}"/>

                        <DataGridTextColumn Header="Ghi chú"
                                            Width="*"
                                            Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <DockPanel Grid.Row="4" Margin="0,16,0,0">
            <TextBlock x:Name="txtTotalAmount"
                       FontSize="16"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Text="Tổng tiền: 0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Content="Hủy"
                        Width="100"
                        Height="36"
                        Margin="0,0,10,0"
                        Click="BtnCancel_Click"/>
                <Button Content="Lưu"
                        Width="120"
                        Height="36"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
