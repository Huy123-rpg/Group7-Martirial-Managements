<Window x:Class="WPF.PresentationLayer.Views.Export.SalesOrderAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đơn bán hàng"
        Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Đơn bán hàng (Sales Order)"
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Mã SO"/>
                <TextBox x:Name="txtCode" Height="34"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Ngày đặt hàng"/>
                <DatePicker x:Name="dpOrderDate" Height="34"/>
            </StackPanel>

            <StackPanel Grid.Column="4" Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Ngày cần giao"/>
                <DatePicker x:Name="dpRequiredDate" Height="34"/>
            </StackPanel>

            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="Khách hàng"/>
                <ComboBox x:Name="cbCustomer"
                          DisplayMemberPath="CustomerName"
                          SelectedValuePath="Id"
                          Height="34"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="Kho xuất"/>
                <ComboBox x:Name="cbWarehouse"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          Height="34"/>
            </StackPanel>

            <StackPanel Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="2">
                <TextBlock Text="Ghi chú"/>
                <TextBox x:Name="txtNote" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <GroupBox Grid.Row="2" Header="Chi tiết đơn hàng" FontWeight="SemiBold">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Thêm dòng" Width="100" Height="32" Click="BtnAddItem_Click"/>
                    <Button Content="Xóa dòng" Width="100" Height="32" Margin="10,0,0,0" Click="BtnDeleteItem_Click"/>
                </StackPanel>

                <DataGrid x:Name="dgItems" Grid.Row="1"
                          AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Sản phẩm" Width="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="ProductName"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding ProductId, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"
                                              StaysOpenOnEdit="True"
                                              LostFocus="ProductComboBox_LostFocus"
                                              SelectionChanged="ProductComboBox_SelectionChanged"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="SL đặt" Width="120"
                                            Binding="{Binding QtyOrdered, ValidatesOnExceptions=True, TargetNullValue=0, FallbackValue=0}"/>
                        <DataGridTextColumn Header="Đơn giá" Width="120"
                                            Binding="{Binding UnitPrice, ValidatesOnExceptions=True, TargetNullValue=0, FallbackValue=0}"/>
                        <DataGridTextColumn Header="Thành tiền" Width="140" IsReadOnly="True"
                                            Binding="{Binding LineTotal, StringFormat=N0}"/>
                        <DataGridTextColumn Header="Ghi chú" Width="*"
                                            Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <DockPanel Grid.Row="3" Margin="0,16,0,0">
            <TextBlock x:Name="txtTotalAmount"
                       FontSize="16" FontWeight="Bold"
                       VerticalAlignment="Center"
                       Text="Tổng tiền: 0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Content="Hủy" Width="100" Height="36" Margin="0,0,10,0" Click="BtnCancel_Click"/>
                <Button Content="Lưu" Width="120" Height="36" Click="BtnSave_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
