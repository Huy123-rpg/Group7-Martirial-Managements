<UserControl x:Class="WPF.PresentationLayer.Views.Inventory.InventoryLookupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Tra Cứu Tồn Kho" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <!-- Chon kho -->
                <TextBlock Text="Kho:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <ComboBox Width="200" Margin="0,0,20,0"
                          ItemsSource="{Binding Warehouses}"
                          SelectedItem="{Binding SelectedWarehouse}"
                          DisplayMemberPath="Name" />

                <!-- Tim kiem -->
                <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <TextBox Width="250" Margin="0,0,15,0" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         VerticalContentAlignment="Center"
                         Padding="5,0"/>
                
                <Button Content="🔍 Tìm" Command="{Binding SearchCommand}" 
                        Width="80" Height="30" Background="#3498DB" Foreground="White" 
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding Inventories}" 
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E2E8F0"
                  BorderBrush="#E2E8F0" BorderThickness="1"
                  RowHeight="35"
                  Background="White"
                  AlternatingRowBackground="#F8FAFC">
            
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F1F5F9"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã SP" Binding="{Binding Product.Sku}" Width="100"/>
                <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding Product.ProductName}" Width="*"/>
                <DataGridTextColumn Header="Kho" Binding="{Binding Warehouse.Name}" Width="150"/>
                
                <DataGridTextColumn Header="Tồn (Thực tế)" Binding="{Binding QtyOnHand, StringFormat={}{0:N0}}" Width="100"/>
                <DataGridTextColumn Header="Khả dụng" Binding="{Binding QtyAvailable, StringFormat={}{0:N0}}" Width="100"/>
                <DataGridTextColumn Header="Đang về" Binding="{Binding QtyIncoming, StringFormat={}{0:N0}}" Width="100"/>
                
                <DataGridTextColumn Header="Giá vốn" Binding="{Binding AvgCost, StringFormat={}{0:N0} ₫}" Width="120"/>
                <DataGridTextColumn Header="Tổng giá trị" Binding="{Binding TotalValue, StringFormat={}{0:N0} ₫}" Width="140"/>
                
                <DataGridTextColumn Header="Cập nhật lần cuối" Binding="{Binding LastUpdated, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
