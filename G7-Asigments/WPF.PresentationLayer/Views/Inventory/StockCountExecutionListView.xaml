<UserControl x:Class="WPF.PresentationLayer.Views.Inventory.StockCountExecutionListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Thực Hiện Kiểm Kho (Nhiệm vụ của tôi)" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

        <!-- DataGrid Danh sach phien kiem kho -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Sessions}" 
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E2E8F0"
                  BorderBrush="#E2E8F0" BorderThickness="1"
                  RowHeight="40"
                  Background="White"
                  AlternatingRowBackground="#F8FAFC">
            
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F1F5F9"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Phiếu" Binding="{Binding SessionCode}" Width="120"/>
                <DataGridTextColumn Header="Kho" Binding="{Binding Warehouse.Name}" Width="180"/>
                <DataGridTextColumn Header="Loại Kiểm" Binding="{Binding CountType}" Width="100"/>
                <DataGridTextColumn Header="Ngày Dự Kiến" Binding="{Binding PlannedDate, StringFormat={}{0:dd/MM/yyyy}}" Width="120"/>
                <DataGridTextColumn Header="Trạng Thái" Binding="{Binding Status.StatusName}" Width="150"/>
                <DataGridTextColumn Header="Ghi Chú" Binding="{Binding Notes}" Width="*"/>
                
                <DataGridTemplateColumn Header="Thao Tác" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Thực hiện" 
                                    Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Background="#3498DB" Foreground="White" BorderThickness="0"
                                    Width="80" Height="28" Cursor="Hand"
                                    FontWeight="SemiBold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
