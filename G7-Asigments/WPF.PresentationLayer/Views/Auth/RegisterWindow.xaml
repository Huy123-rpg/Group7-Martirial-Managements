<Window x:Class="WPF.PresentationLayer.Views.Auth.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WPF.PresentationLayer.ViewModels.Auth"
        Title="Tạo tài khoản — Quản lý Kho"
        Height="580" Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBackground}">



    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
              Width="380" Margin="0,24">
            <Border Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="40,36">
                <StackPanel>

                    <!-- Header -->
                    <TextBlock Text="TẠO TÀI KHOẢN MỚI"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource BrushTextPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Điền đầy đủ thông tin để đăng ký"
                               FontSize="12"
                               Foreground="{StaticResource BrushTextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>

                    <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,20,0,4"/>

                    <!-- Full Name -->
                    <Label Content="HỌ VÀ TÊN" FontSize="11" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"/>

                    <!-- Email -->
                    <Label Content="EMAIL" FontSize="11" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" MaxLength="150"/>

                    <!-- Password -->
                    <Label Content="MẬT KHẨU" FontSize="11" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="txtPassword" MaxLength="100"/>
                    <TextBlock Text="Tối thiểu 8 ký tự"
                               FontSize="11"
                               Foreground="{StaticResource BrushTextSecondary}"
                               Margin="0,2,0,0"/>

                    <!-- Confirm Password -->
                    <Label Content="XÁC NHẬN MẬT KHẨU" FontSize="11" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="txtConfirmPassword" MaxLength="100"/>

                    <!-- Role -->
                    <Label Content="VAI TRÒ" FontSize="11" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Roles}"
                              SelectedItem="{Binding SelectedRole}"
                              DisplayMemberPath="RoleName"/>

                    <!-- Error -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource BrushError}"
                               FontSize="12"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding ErrorVisibility}"/>

                    <!-- Register Button -->
                    <Button Content="ĐĂNG KÝ"
                            Style="{StaticResource ButtonPrimary}"
                            Margin="0,20,0,0"
                            Command="{Binding RegisterCommand}"/>

                    <!-- Back to Login -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,0"
                                Visibility="{Binding BackToLoginVisibility}">
                        <TextBlock Text="Đã có tài khoản?  "
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   VerticalAlignment="Center"/>
                        <Button Content="Đăng nhập"
                                Style="{StaticResource ButtonLink}"
                                Command="{Binding NavigateToLoginCommand}"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
