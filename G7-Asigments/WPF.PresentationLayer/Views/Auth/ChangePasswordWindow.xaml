<Window x:Class="WPF.PresentationLayer.Views.Auth.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WPF.PresentationLayer.ViewModels.Auth"
        Title="Đổi mật khẩu lần đầu đăng nhập"
        Height="420" Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBackground}">



    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
        <Border Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="2"
                Padding="40,36">
            <StackPanel>

                <!-- Header -->
                <TextBlock Text="ĐỔI MẬT KHẨU"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextPrimary}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Bạn phải đổi mật khẩu trước khi tiếp tục"
                           FontSize="12"
                           Foreground="{StaticResource BrushTextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>

                <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,20,0,4"/>

                <!-- Current Password -->
                <Label Content="MẬT KHẨU HIỆN TẠI" FontSize="11" FontWeight="SemiBold"/>
                <PasswordBox x:Name="CurrentPasswordBox" MaxLength="100"/>

                <!-- New Password -->
                <Label Content="MẬT KHẨU MỚI" FontSize="11" FontWeight="SemiBold"/>
                <PasswordBox x:Name="NewPasswordBox" MaxLength="100"/>
                <TextBlock Text="Tối thiểu 8 ký tự"
                           FontSize="11"
                           Foreground="{StaticResource BrushTextSecondary}"
                           Margin="0,2,0,0"/>

                <!-- Confirm New Password -->
                <Label Content="XÁC NHẬN MẬT KHẨU MỚI" FontSize="11" FontWeight="SemiBold"/>
                <PasswordBox x:Name="ConfirmPasswordBox" MaxLength="100"/>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource BrushError}"
                           FontSize="12"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorVisibility}"/>

                <!-- Confirm Button -->
                <Button Content="XÁC NHẬN"
                        Style="{StaticResource ButtonPrimary}"
                        Margin="0,20,0,0"
                        Command="{Binding ConfirmCommand}"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
