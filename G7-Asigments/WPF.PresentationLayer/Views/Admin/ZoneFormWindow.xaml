<Window x:Class="WPF.PresentationLayer.Views.Admin.ZoneFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBackground}">

    <StackPanel Margin="28,24">

        <!-- Error Banner -->
        <Border Background="#FFEBEE" BorderBrush="#C62828" BorderThickness="1"
                CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                Visibility="{Binding ErrorVisibility}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" TextWrapping="Wrap"/>
        </Border>

        <!-- Mã zone -->
        <TextBlock Text="Mã zone *" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" Margin="0,0,0,4"/>
        <TextBox Text="{Binding ZoneCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

        <!-- Tên zone -->
        <TextBlock Text="Tên zone" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" Margin="0,0,0,4"/>
        <TextBox Text="{Binding ZoneName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

        <!-- Loại zone -->
        <TextBlock Text="Loại zone *" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" Margin="0,0,0,4"/>
        <ComboBox ItemsSource="{Binding ZoneTypes}"
                  SelectedItem="{Binding SelectedZoneType}"
                  DisplayMemberPath="TypeName"
                  Margin="0,0,0,10"/>

        <!-- Sức chứa m³ -->
        <TextBlock Text="Sức chứa (m³)" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" Margin="0,0,0,4"/>
        <TextBox Text="{Binding CapacityM3, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

        <!-- Sức chứa pallet -->
        <TextBlock Text="Số pallet tối đa" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" Margin="0,0,0,4"/>
        <TextBox Text="{Binding CapacityPallet, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Hủy" Width="90" Margin="0,0,10,0"
                    Command="{Binding CancelCommand}"/>
            <Button Content="Lưu" Width="100" Style="{StaticResource ButtonPrimary}"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </StackPanel>
</Window>
