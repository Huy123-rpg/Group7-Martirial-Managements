<UserControl x:Class="WPF.PresentationLayer.Views.Admin.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WPF.PresentationLayer.ViewModels.Admin">

    <UserControl.DataContext>
        <vm:DashboardViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BrushSurface}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="2"/>
            <Setter Property="Padding"         Value="24,20"/>
            <Setter Property="Width"           Value="210"/>
            <Setter Property="Margin"          Value="0,0,16,16"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">

            <!-- Section: Hệ thống -->
            <TextBlock Text="Hệ thống"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextSecondary}"
                       Margin="0,0,0,10"/>
            <WrapPanel Margin="0,0,0,8">
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalUsers}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <TextBlock Text="Tổng người dùng" FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding ActiveUsers}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <TextBlock Text="Tài khoản hoạt động" FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalProducts}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <TextBlock Text="Sản phẩm" FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalWarehouses}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <TextBlock Text="Kho hàng" FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Section: Chờ xử lý -->
            <TextBlock Text="Chờ xử lý"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextSecondary}"
                       Margin="0,8,0,10"/>
            <WrapPanel Margin="0,0,0,8">
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding PendingPO}" FontSize="32" FontWeight="Bold"
                                   Foreground="#F59E0B"/>
                        <TextBlock Text="PO chờ duyệt" FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding PendingSO}" FontSize="32" FontWeight="Bold"
                                   Foreground="#F59E0B"/>
                        <TextBlock Text="SO chờ duyệt" FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding PendingGRN}" FontSize="32" FontWeight="Bold"
                                   Foreground="#F59E0B"/>
                        <TextBlock Text="Phiếu nhập chờ duyệt" FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding PendingGI}" FontSize="32" FontWeight="Bold"
                                   Foreground="#F59E0B"/>
                        <TextBlock Text="Phiếu xuất chờ duyệt" FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Section: Tồn kho -->
            <TextBlock Text="Tồn kho"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextSecondary}"
                       Margin="0,8,0,10"/>
            <WrapPanel>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding LowStockCount}" FontSize="32" FontWeight="Bold"
                                   Foreground="#EF4444"/>
                        <TextBlock Text="Sản phẩm sắp hết (≤10)" FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Width="260">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalInventoryValue}" FontSize="20" FontWeight="Bold"
                                   Foreground="#10B981" TextWrapping="Wrap"/>
                        <TextBlock Text="Tổng giá trị tồn kho" FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
