<UserControl x:Class="WPF.PresentationLayer.Views.Admin.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WPF.PresentationLayer.ViewModels.Admin">

    <UserControl.DataContext>
        <vm:DashboardViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BrushSurface}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="2"/>
            <Setter Property="Padding"         Value="24,20"/>
            <Setter Property="Width"           Value="210"/>
            <Setter Property="Margin"          Value="0,0,16,16"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">

            <!-- Section title -->
            <TextBlock Text="Tổng quan hệ thống"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextSecondary}"
                       Margin="0,0,0,16"/>

            <!-- Stat Cards Row -->
            <WrapPanel>

                <!-- Tổng người dùng -->
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalUsers}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <TextBlock Text="Tổng người dùng"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Đang hoạt động -->
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding ActiveUsers}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <TextBlock Text="Tài khoản hoạt động"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Sản phẩm -->
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalProducts}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <TextBlock Text="Sản phẩm"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Kho -->
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalWarehouses}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <TextBlock Text="Kho hàng"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
