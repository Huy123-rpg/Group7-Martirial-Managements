<UserControl x:Class="WPF.PresentationLayer.Views.Admin.WarehouseConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WPF.PresentationLayer.ViewModels.Admin">

    <UserControl.DataContext>
        <vm:WarehouseConfigViewModel/>
    </UserControl.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Header ══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Cấu hình kho &amp; zone"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource BrushTextPrimary}"/>
            <TextBlock FontSize="12" Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                <Setter Property="Text" Value="Quyền: Toàn quyền CRUD kho và zone"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsManagerOnly}" Value="True">
                                <Setter Property="Text" Value="Quyền: Xem và đề xuất thay đổi — Admin sẽ xét duyệt"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- ══ Two-pane ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════ LEFT PANE — Warehouses ══════ -->
            <Border Grid.Column="0"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1" CornerRadius="4">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Title + Toolbar -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="📦 Danh sách kho"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <!-- Admin toolbar -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}">
                                <Button Content="+ Thêm" Margin="4,0,0,0"
                                        Style="{StaticResource ButtonPrimary}"
                                        Padding="12,0"
                                        Command="{Binding AddWarehouseCommand}"/>
                                <Button Content="✎ Sửa" Margin="4,0,0,0"
                                        Padding="12,0"
                                        Command="{Binding EditWarehouseCommand}"/>
                                <Button Margin="4,0,0,0" Padding="12,0"
                                        Command="{Binding ToggleWarehouseCommand}">
                                    <Button.Content>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Toggle"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedWarehouse.IsActive}" Value="True">
                                                            <Setter Property="Text" Value="🚫 Vô hiệu"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedWarehouse.IsActive}" Value="False">
                                                            <Setter Property="Text" Value="✅ Kích hoạt"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button.Content>
                                </Button>
                                <Button Content="🗑 Xóa" Margin="4,0,0,0" Padding="12,0"
                                        Foreground="#C62828" BorderBrush="#EF9A9A"
                                        Command="{Binding DeleteWarehouseCommand}"/>
                            </StackPanel>
                            <!-- Manager toolbar -->
                            <Button Content="📋 Đề xuất" Margin="4,0,0,0" Padding="12,0"
                                    Command="{Binding ProposeWarehouseCommand}"
                                    Visibility="{Binding IsManagerOnly, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Search box -->
                    <TextBox Grid.Row="1" Margin="0,0,0,8"
                             Text="{Binding WarehouseSearch, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Warehouses}"
                              SelectedItem="{Binding SelectedWarehouse}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="Transparent"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#08000000"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã" Binding="{Binding Code}" Width="80"/>
                            <DataGridTextColumn Header="Tên kho" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Thành phố" Binding="{Binding City}" Width="90"/>
                            <DataGridTextColumn Header="Quản lý" Binding="{Binding Manager.FullName}" Width="110"/>
                            <DataGridTemplateColumn Header="Trạng thái" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="#1A2E7D32"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Background" Value="#1AC62828"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Text" Value="Hoạt động"/>
                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Text" Value="Vô hiệu"/>
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>


        </Grid>
    </Grid>
</UserControl>
